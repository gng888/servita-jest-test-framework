{
  "name": "servita-automation-suite",
  "version": "1.0.0",
  "description": "Servita Automated test suite – Playwright (UI e2e) and Jest/Axios (API integration) in TypeScript",
  "scripts": {
    "test": "npm run test:ui && npm run test:api",
    "test:ui": "npx playwright test",
    "test:ui:debug": "npx playwright test --headed --debug --workers=1",
    "test:ui:headed": "npx playwright test --headed --workers=1",
    "test:ui:auth": "npx playwright test --grep @auth",
    "test:ui:checkout-single": "npx playwright test --grep @checkout-single",
    "test:ui:checkout-multiple": "npx playwright test --grep @checkout-multiple",
    "test:ui:negative": "npx playwright test --grep @negativetests",
    "test:ui:report": "npx playwright show-report tests/ui/reports",
    "test:api": "jest --config jest.config.ts",
    "test:api:report": "open tests/api/reports/api-report.html",
    "lint": "tsc --noEmit"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "^1.51.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "axios": "^1.8.4",
    "dotenv": "^16.4.7",
    "jest": "^29.7.0",
    "jest-html-reporter": "^4.0.2",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
